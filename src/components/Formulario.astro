<section class="formulario-container">
  <div class="formulario-wrapper">
    <h2 class="formulario-title">Asesórate sobre Barrio Hub</h2>
    <p class="formulario-subtitle">
      Si quieres que te asesoremos sobre Barrio Hub y nuestros servicios, contacta con nosotros. 
      Te responderemos en breve.
    </p>
    
    <form class="formulario-form">
      <div class="form-group">
        <input 
          type="text" 
          placeholder="Tu nombre" 
          class="form-input" 
          required 
        />
      </div>
      
      <div class="form-group">
        <input 
          type="email" 
          placeholder="Tu correo" 
          class="form-input" 
          required 
        />
      </div>
      
      <div class="form-group">
        <input 
          type="tel" 
          placeholder="Tu teléfono (opcional)" 
          class="form-input" 
        />
      </div>
      
      <div class="form-group">
        <textarea 
          placeholder="Tu mensaje" 
          class="form-textarea" 
          rows="5" 
          required
        ></textarea>
      </div>
      
      <button type="submit" class="form-button">Enviar Solicitud</button>
    </form>
  </div>
</section>
